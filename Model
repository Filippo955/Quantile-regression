#Model with Regions

#(Abdullah, 2016)
taus <- c(0.50, 0.75, 0.90)

QR1 <- rq(INC ~ EDU + SUS + LAN + POP + RAI + HIG + AIR + POR + factor(REG),
tau = taus, data = Accessibility_)
summary(QR1)
summary(QR1, se = "boot", R = 1000) 


# (n.d. ,2023)

pseudo_R2 <- sapply(taus, function(tau) {
  
fit0 <- rq(INC ~ 1, tau = tau, data = Accessibility_)
  
  
fit1 <- rq(INC ~ EDU + SUS + LAN + RAI + HIG + AIR + POR + POP + factor(REG),
tau = tau, data = Accessibility_)
  
1 - fit1$rho / fit0$rho})

names(pseudo_R2) <- paste0("tau_", taus)

pseudo_R2     




