norm_minmax <- function(x) {
  (x - min(x, na.rm = TRUE)) / (max(x, na.rm = TRUE) - min(x, na.rm = TRUE))}

norm_minmax_inv <- function(x) {
  1 - norm_minmax(x)}

var_Positive <- c("EDU", "SUS", "LAN", "TEC")
var_negative <- c("RAI", "HIG", "AIR", "POR")


Accessibility_ <- Accessibility_ %>%
mutate(across(all_of(var_Positive), ~ . / 100),                
across(all_of(var_negative), norm_minmax_inv),          
INC = norm_minmax(INC), POP = norm_minmax(POP))                           
  

OLS1 <- lm(INC ~ EDU + SUS + LAN + RAI + HIG + AIR + POR + POP + factor(REG),
data = Accessibility_)

summary(OLS1)


OLS2 <- lm(INC ~ EDU + SUS + LAN + RAI + HIG + AIR + POR + POP + factor(AREA),
data = Accessibility_)

summary(OLS2)

OLS3 <- lm(INC ~ EDU + SUS + LAN + TEC + RAI + HIG + AIR + POR + POP + factor(REG), 
data = Accessibility_)

summary(OLS3)

OLS4 <- lm(INC ~ EDU + SUS + LAN + TEC + RAI + HIG + AIR + POR + POP + factor(AREA),
data = Accessibility_)

summary(OLS4)


# VIF 
vif(OLS1)
vif(OLS2)
vif(OLS3)
vif(OLS4)

