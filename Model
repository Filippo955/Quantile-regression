Accessibility_$REG %in% c("Trentino-Alto Adige/Südtirol", "Veneto","Friuli-Venezia Giulia", "Emilia-Romagna") ~ "North East",
  
Accessibility_$REG %in% c("Toscana", "Umbria", "Marche", "Lazio") ~ "Centre",
  
